DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-value
# Optional: DATABASE_URL=postgresql://sitehits:password@127.0.0.1:5432/sitehits
ALLOWED_HOSTS=sitehits.io
CSRF_TRUSTED_ORIGINS=https://sitehits.io
