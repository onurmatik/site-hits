DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-value
# Optional: DATABASE_URL=postgresql://sitehits:password@127.0.0.1:5432/sitehits
ALLOWED_HOSTS=sitehits.io
CSRF_TRUSTED_ORIGINS=https://sitehits.io
SITEHITS_BASE_URL=https://sitehits.io
SITEHITS_HASH_SECRET=replace-with-an-independent-long-random-value
SITEHITS_GEOIP_DB_PATH=/app/data/GeoLite2-Country.mmdb
SITEHITS_TIME_ZONE=Europe/Istanbul
SITEHITS_TRUST_PROXY_HEADERS=true
SITEHITS_MAX_EVENT_BYTES=16384

# Google OAuth web application. Add this authorized redirect URI:
# https://sitehits.io/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Local development defaults to Django's console backend. Production defaults
# to the SES API backend and requires dedicated SES IAM credentials. The region
# must match the region where the sitehits.io identity is verified.
DJANGO_EMAIL_BACKEND=django_ses.SESBackend
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION_NAME=
# Optional; derived as email.<region>.amazonaws.com when omitted.
AWS_SES_REGION_ENDPOINT=
USE_SES_V2=true
# Optional SES configuration set for delivery/bounce monitoring.
AWS_SES_CONFIGURATION_SET=
DEFAULT_FROM_EMAIL=SiteHits <hello@sitehits.io>
